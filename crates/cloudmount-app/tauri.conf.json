{
  "productName": "CloudMount",
  "version": "0.1.0-rc.2",
  "identifier": "com.cloudmount",
  "build": {
    "frontendDist": "./dist"
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libfuse3-3"],
        "desktopTemplate": null
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "entitlements": null
    },
    "windows": {
      "nsis": {
        "languages": ["English"]
      }
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {}
  },
  "plugins": {
    "notification": null,
    "updater": {
      "endpoints": ["https://github.com/Nyxa07/cloud-mount/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJENzNCNTg0QzNCOUE5QTMKUldTanFibkRoTFZ6TFFWMUNtMlRhN1pEdHh0Ungxckx0OXdGSXhjUUJLWDZ5SFJuOFhTbVNHaWIK"
    }
  }
}
