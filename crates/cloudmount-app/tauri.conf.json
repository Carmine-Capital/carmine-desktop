{
  "productName": "CloudMount",
  "version": "0.1.0",
  "identifier": "com.cloudmount.app",
  "build": {
    "frontendDist": "./dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libfuse3-3"],
        "desktopTemplate": null
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "entitlements": null
    },
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": null
    }
  },
  "app": {
    "windows": [],
    "security": {}
  },
  "plugins": {
    "notification": {}
  }
}
