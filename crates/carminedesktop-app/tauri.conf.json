{
  "productName": "Carmine Desktop",
  "version": "0.1.0-rc.40",
  "identifier": "com.carmine-capital.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "./frontend/dist"
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "windows/hooks.nsh",
        "languages": [
          "English"
        ]
      }
    },
    "resources": {
      "icons/files/doc.ico": "icons/doc.ico",
      "icons/files/xls.ico": "icons/xls.ico",
      "icons/files/ppt.ico": "icons/ppt.ico",
      "icons/files/pdf.ico": "icons/pdf.ico"
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {}
  },
  "plugins": {
    "notification": null,
    "deep-link": {
      "desktop": {
        "schemes": [
          "carminedesktop"
        ]
      }
    },
    "updater": {
      "endpoints": [
        "https://static.carminecapital.com/carmine-desktop/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQxMzU4NjE4OTM4MUY0OTMKUldTVDlJR1RHSVkxMFhCQVUyS2RyLzg4a0RqY0J0ek81LzJUT0dta0NZZU5EREJESWFlMVY3blkK"
    }
  }
}
